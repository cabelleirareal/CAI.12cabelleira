{
    "name": "cabelleira-ia",
    "description": "Aplicação Cabelleira Real com Gemini API",
    "version": "1.0.0",
    "domain": "www.cabelleiraia.cloud",
    "build": {
          "command": "npm install && npm run build",
          "outputDirectory": "dist"
    },
    "start": {
          "command": "npm start",
          "port": 3000
    },
    "nodeVersion": "20.x",
    "environment": {
          "NODE_ENV": "production"
    },
    "environmentVariables": [
          {
                  "key": "GEMINI_API_KEY",
                  "value": "${GEMINI_API_KEY}",
                  "required": true,
                  "sensitive": true
          }
    ],
    "ssl": {
          "enabled": true,
          "provider": "letsencrypt"
    },
    "healthCheck": {
          "enabled": true,
          "path": "/",
          "interval": 30,
          "timeout": 10,
          "retries": 3
    },
    "deployment": {
          "autoRedeploy": true,
          "webhook": true,
          "branch": "main"
    }
}
